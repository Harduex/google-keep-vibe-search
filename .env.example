# Path to the Google Keep export folder
# Linux:   /home/user/Takeout/Keep
# Windows: C:\Users\user\Takeout\Keep
GOOGLE_KEEP_PATH=

# Search settings
MAX_RESULTS=300
SEARCH_THRESHOLD=0.3

# Embedding model for semantic search (sentence-transformers model name)
# Default supports 50+ languages including English and Bulgarian
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# Clustering settings
DEFAULT_NUM_CLUSTERS=20

# Server settings
HOST=127.0.0.1
PORT=8000

# LLM settings
# Provider: ollama (default), openai, anthropic, or any LiteLLM-supported provider
# LiteLLM docs: https://docs.litellm.ai/docs/providers
LLM_PROVIDER=ollama
LLM_API_BASE_URL=
LLM_API_KEY=
LLM_MODEL=deepseek-r1:14b
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048
CHAT_CONTEXT_NOTES=10

# Agentic retrieval (Phase 8B) — NotebookLM-style iterative search
# When enabled, an AI agent searches, evaluates coverage, and refines
# context iteratively before generating the response.
ENABLE_AGENT_MODE=false
AGENT_MAX_STEPS=5

# Conversation settings
CHAT_MAX_RECENT_MESSAGES=6
CHAT_SUMMARIZATION_THRESHOLD=12

# Legacy Ollama URL (used as fallback if LLM_API_BASE_URL is empty)
# Native install:  http://localhost:11434
# Docker Desktop:  http://host.docker.internal:11434
# Linux Docker:    http://172.17.0.1:11434
OLLAMA_API_URL=http://localhost:11434

# Enable/disable image search (requires CLIP model download)
ENABLE_IMAGE_SEARCH=true
# Image search tuning (advanced)
IMAGE_SEARCH_THRESHOLD=0.2
IMAGE_SEARCH_WEIGHT=0.3

# Cross-encoder reranker for improved search precision
ENABLE_RERANKER=true
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L6-v2

# Entity resolution for named entity-based retrieval
ENABLE_ENTITY_RESOLUTION=true

# Citation verification (NLI) + grounding scores
ENABLE_CITATION_VERIFICATION=true
NLI_MODEL=cross-encoder/nli-deberta-v3-small

# Prompt decomposition (breaks complex queries into sub-queries)
ENABLE_PROMPT_DECOMPOSITION=true

# Gap analysis (CRAG-style adaptive retrieval)
ENABLE_GAP_ANALYSIS=true

# Cache directory (leave empty for default ./cache/)
CACHE_DIR=

# When true the app ignores existing caches and re-processes notes/embeddings
# Useful during development when you change your Keep export or want a fresh
# index without deleting the cache directory manually.
FORCE_CACHE_REFRESH=false
