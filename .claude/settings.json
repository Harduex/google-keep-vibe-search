{
  "permissions": {
    "allow": [
      "Bash(python -m pytest *)",
      "Bash(pytest *)",
      "Bash(black *)",
      "Bash(isort *)",
      "Bash(cd client && npm run *)",
      "Bash(cd client && npx prettier *)",
      "Bash(cd client && npx eslint *)",
      "Bash(cd client && npx vitest *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(pre-commit run *)"
    ],
    "deny": [
      "Bash(rm -rf /)*",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(*> .env*)",
      "Read(./.env)",
      "Read(./.env.*)"
    ]
  }
}
